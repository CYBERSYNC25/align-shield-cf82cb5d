# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="your-supabase-url"

# Cloudflare Turnstile (Captcha)
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"

# ---------------------------------------------------------------------------
# SECRETS DO SUPABASE (configurar no Dashboard: Project Settings → Edge Functions → Secrets)
# Não coloque aqui; são variáveis de servidor.
# ---------------------------------------------------------------------------
# TOKEN_ENCRYPTION_KEY = chave 32 bytes em hex (ex: openssl rand -hex 32)
#   Obrigatória para: salvar credenciais de integrações (Cloudflare, Jira, GitHub,
#   GitLab, Slack, BambooHR, CrowdStrike, Intune, Azure AD), OAuth Google/Azure, MFA.
#   Sem ela, "Conectar" nesses provedores retorna erro ao salvar.
